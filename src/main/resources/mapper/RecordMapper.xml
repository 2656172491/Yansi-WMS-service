<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.yansispringboot.mapper.RecordMapper">

    <resultMap id="RecordResultMap" type="org.example.yansispringboot.pojo.Record">
        <id column="id" property="id"/>
        <result column="goods_id" property="goodsId"/>
        <result column="warehouse_id" property="warehouseId"/>
        <result column="type" property="type"/>
        <result column="quantity" property="quantity"/>
        <result column="before_quantity" property="beforeQuantity"/>
        <result column="after_quantity" property="afterQuantity"/>
        <result column="operator" property="operator"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectById" resultMap="RecordResultMap">
        SELECT * FROM records WHERE id = #{id}
    </select>

    <select id="selectPage" resultMap="RecordResultMap">
        SELECT * FROM records
        <where>
            <if test="goodsId != null">
                AND goods_id = #{goodsId}
            </if>
            <if test="warehouseId != null">
                AND warehouse_id = #{warehouseId}
            </if>
            <if test="type != null">
                AND type = #{type}
            </if>
        </where>
        ORDER BY id DESC
        LIMIT #{offset}, #{pageSize}
    </select>

    <select id="countByCondition" resultType="long">
        SELECT COUNT(*) FROM records
        <where>
            <if test="goodsId != null">
                AND goods_id = #{goodsId}
            </if>
            <if test="warehouseId != null">
                AND warehouse_id = #{warehouseId}
            </if>
            <if test="type != null">
                AND type = #{type}
            </if>
        </where>
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO records (goods_id, warehouse_id, type, quantity, before_quantity, after_quantity, operator, remark, create_time)
        VALUES (#{goodsId}, #{warehouseId}, #{type}, #{quantity}, #{beforeQuantity}, #{afterQuantity}, #{operator}, #{remark}, NOW())
    </insert>

</mapper>
